// ══ PRO: DIFERIDOS ════════════════════════════════════════
async function cargarDiferidos() {
  const lista = document.getElementById('diferidos-lista');
  lista.innerHTML = '<p style="color:var(--muted);font-size:13px;">Cargando...</p>';
  try {
    const data = await fetch(scriptUrl + '?cmd=diferidos', { redirect: 'follow' }).then(r => r.json());
    if (!data.length) { lista.innerHTML = '<p class="empty-state">Sin diferidos registrados.</p>'; return; }
    const activos   = data.filter(d => d.activo && d.cuotasRest > 0);
    const inactivos = data.filter(d => !d.activo || d.cuotasRest <= 0);

    function renderDif(d) {
      const completado = d.cuotasRest <= 0 || !d.activo;
      return `<div class="dif-item ${completado ? 'dif-completado' : ''}" id="dif-${d.nombre.replace(/\s/g,'_')}">
        <div class="dif-header">
          <div>
            <div class="dif-nombre">${d.nombre} ${completado ? '✅' : ''}</div>
            <div class="dif-meta">${d.categoria} · ${d.metodo} · día ${d.diaCobro}</div>
          </div>
          <div class="dif-derecha">
            <div class="dif-cuotas">${d.cuotasPagadas}/${d.cuotasTotal}</div>
            <div class="dif-restante">Termina: ${d.finLabel}</div>
          </div>
        </div>
        <div class="dif-barra-track"><div class="dif-barra-fill" style="width:${d.pct}%"></div></div>
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-bottom:8px;">
          <span>$${parseFloat(d.montoCuota).toFixed(2)}/cuota</span>
          <span>Resto: $${parseFloat(d.montoRest).toFixed(2)}</span>
        </div>
        ${!completado ? `<div class="dif-acciones">
          <button class="dif-saldar-btn" onclick="saldarDiferido('${d.nombre}',${d.montoRest},${d.cuotasTotal})">Saldar todo $${parseFloat(d.montoRest).toFixed(2)}</button>
          ${ultimoSaldadoInfo?.nombre === d.nombre ? `<button class="dif-undo-btn" onclick="undoSaldar('${d.nombre}',${ultimoSaldadoInfo.cuotasPagadas})">↩ Deshacer</button>` : ''}
          <button class="dif-del-btn" onclick="eliminarDiferido('${d.nombre}')">🗑</button>
        </div>` : `<div class="dif-acciones"><button class="dif-del-btn" style="flex:1;" onclick="eliminarDiferido('${d.nombre}')">🗑 Eliminar</button></div>`}
      </div>`;
    }

    lista.innerHTML = activos.map(renderDif).join('') +
      (inactivos.length ? `<div style="color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:0.5px;margin:16px 0 8px;">Completados</div>` + inactivos.map(renderDif).join('') : '');
  } catch { lista.innerHTML = '<p class="error">Error al cargar.</p>'; }
}

async function saldarDiferido(nombre, montoRest, cuotasTotal) {
  if (!confirm(`¿Saldar "${nombre}" ($${parseFloat(montoRest).toFixed(2)} restantes)?`)) return;
  try {
    // Guardar info para undo
    const data = await fetch(scriptUrl + '?cmd=diferidos', { redirect: 'follow' }).then(r => r.json());
    const d = data.find(x => x.nombre === nombre);
    if (d) ultimoSaldadoInfo = { nombre, cuotasPagadas: d.cuotasPagadas, cuotasTotal };

    const params = new URLSearchParams({ cmd: 'saldar_diferido', nombre, montoRest, categoria: d?.categoria || '', metodo: d?.metodo || '', cuotasTotal });
    const res = await fetch(scriptUrl + '?' + params.toString(), { redirect: 'follow' });
    mostrarToast(await res.text());
    cargarDiferidos();
  } catch { mostrarToast('Error al saldar'); }
}

async function undoSaldar(nombre, cuotasPagadasAntes) {
  try {
    const data = await fetch(scriptUrl + '?cmd=diferidos', { redirect: 'follow' }).then(r => r.json());
    const d = data.find(x => x.nombre === nombre);
    const params = new URLSearchParams({ cmd: 'deshacer_saldar', nombre, cuotasPagadas: cuotasPagadasAntes, cuotasTotal: d?.cuotasTotal || 0 });
    const res = await fetch(scriptUrl + '?' + params.toString(), { redirect: 'follow' });
    mostrarToast(await res.text());
    ultimoSaldadoInfo = null;
    cargarDiferidos();
  } catch { mostrarToast('Error al deshacer'); }
}

async function eliminarDiferido(nombre) {
  if (!confirm(`¿Eliminar diferido "${nombre}"?`)) return;
  try {
    const res = await fetch(scriptUrl + '?cmd=del_diferido&nombre=' + encodeURIComponent(nombre), { redirect: 'follow' });
    mostrarToast(await res.text());
    cargarDiferidos();
