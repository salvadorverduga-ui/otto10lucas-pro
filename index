// ── TEMAS ─────────────────────────────────────────────────
const TEMAS_VALIDOS = ['obsidian', 'forest', 'arctic', 'sakura'];

function setTema(tema) {
  const html = document.documentElement;
  if (tema === 'obsidian') html.removeAttribute('data-theme');
  else html.setAttribute('data-theme', tema);
  localStorage.setItem('otto_tema', tema);
  TEMAS_VALIDOS.forEach(t => {
    ['dot-'+t, 'dot-'+t+'-cfg'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('active', t === tema);
    });
  });
}

