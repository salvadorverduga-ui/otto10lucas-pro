<script>
// ══════════════════════════════════════════════════════════
// OTTO Y 10 LUCAS — PLAN PRO
// Métodos dinámicos desde Sheet, lógica de cortes de ciclo,
// presupuestos, suscripciones, diferidos, cuentas por cobrar.
// ══════════════════════════════════════════════════════════

const MESES_LABEL = ["Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"];

let scriptUrl = localStorage.getItem('otto_script_url') || '';
let sheetsUrl = localStorage.getItem('otto_sheets_url') || '';

// Datos dinámicos — cargados desde Sheet
let CONFIG_CATS = [];
let CONFIG_METS = [];
let CATS = [];
let METS = [];

let selectedCat = '', selectedMet = '';
let chartInstance = null, historicoLineChart = null, historicoBarChart = null;
let tipoReg = 'gasto';
let mesSeleccionado = new Date().getMonth() + 1;
let anioSeleccionado = new Date().getFullYear();
let historialData = [];
let filtroActivo = 'todos';
let fechaOffsetActivo = 0;
let ultimoSaldadoInfo = null; // para undo diferidos

// (Ajustes accesible desde la 6ta pestaña ⚙️)

if (scriptUrl) iniciarApp();

function guardar() {
  const url = document.getElementById('url-input').value.trim();
  if (!url) return;
  scriptUrl = url;
  localStorage.setItem('otto_script_url', url);
  iniciarApp();
}

async function iniciarApp() {
  document.getElementById('config-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  document.getElementById('bottom-nav').style.display = 'flex';
  const hoy = new Date();
  setFechaRapida(0);
  mesSeleccionado = hoy.getMonth() + 1;
  anioSeleccionado = hoy.getFullYear();

  const yearSel = document.getElementById('year-select');
  yearSel.innerHTML = '';
  for (let y = anioSeleccionado - 1; y <= anioSeleccionado + 1; y++) {
    const opt = document.createElement('option');
    opt.value = y; opt.textContent = y;
    if (y === anioSeleccionado) opt.selected = true;
    yearSel.appendChild(opt);
  }
  document.getElementById('month-select').value = mesSeleccionado;

  ['comp-anio1','comp-anio2'].forEach(id => {
    const sel = document.getElementById(id);
    if (!sel) return;
    sel.innerHTML = '';
    for (let y = anioSeleccionado - 2; y <= anioSeleccionado; y++) {
      const opt = document.createElement('option');
      opt.value = y; opt.textContent = y;
      if (y === anioSeleccionado) opt.selected = true;
      sel.appendChild(opt);
    }
  });

  const m1 = mesSeleccionado, m2 = m1 > 1 ? m1 - 1 : 12;
  document.getElementById('comp-mes1').value = m1;
  document.getElementById('comp-mes2').value = m2;
  if (m2 === 12) { const a2 = document.getElementById('comp-anio2'); if (a2) a2.value = anioSeleccionado - 1; }

  // Fecha de hoy para cobrar modal
  const cobFecha = document.getElementById('cobrar-fecha');
  if (cobFecha) cobFecha.value = new Date().toISOString().split('T')[0];

  // Cargar config dinámica (cats + métodos) primero
  await cargarConfig();
  poblarUI();
  renderFavs();
  cargarHome();
  cargarImpactoSiguiente();

  if (!sheetsUrl) {
    fetch(scriptUrl + '?cmd=info', { redirect: 'follow' })
      .then(r => r.json()).then(d => { if (d.sheets_url) { sheetsUrl = d.sheets_url; localStorage.setItem('otto_sheets_url', sheetsUrl); } }).catch(() => {});
  }
}

// ── Cargar config dinámica desde Sheet ───────────────────
async function cargarConfig() {
  // Intentar desde cache primero
  const cachedCats = leerCacheGlobal('config_cats');
  const cachedMets = leerCacheGlobal('config_mets');
  if (cachedCats && cachedMets) {
    CONFIG_CATS = cachedCats;
    CONFIG_METS = cachedMets;
    CATS = CONFIG_CATS.map(c => c.nombre);
    METS = CONFIG_METS.map(m => m.nombre);
  }

  try {
    const [rCats, rMets] = await Promise.allSettled([
      fetch(scriptUrl + '?cmd=config_cats', { redirect: 'follow' }).then(r => r.json()),
      fetch(scriptUrl + '?cmd=config_mets', { redirect: 'follow' }).then(r => r.json())
    ]);

    if (rCats.status === 'fulfilled' && Array.isArray(rCats.value) && rCats.value.length) {
      CONFIG_CATS = rCats.value;
      CATS = CONFIG_CATS.map(c => c.nombre);
      guardarCacheGlobal('config_cats', CONFIG_CATS);
    }
    if (rMets.status === 'fulfilled' && Array.isArray(rMets.value) && rMets.value.length) {
      CONFIG_METS = rMets.value;
      METS = CONFIG_METS.map(m => m.nombre);
      guardarCacheGlobal('config_mets', CONFIG_METS);
    }
  } catch {}

  // Fallback si no hay nada
  if (!CONFIG_CATS.length) CONFIG_CATS = [
    {nombre:'Transporte',icono:'🚗'},{nombre:'Comida',icono:'🍔'},
    {nombre:'Trámites',icono:'📋'},{nombre:'Tienda',icono:'🛒'},
    {nombre:'Ocio',icono:'🎮'},{nombre:'Necesidad',icono:'🧾'},
    {nombre:'Herramienta',icono:'🔧'},{nombre:'Arriendo',icono:'🏠'},
    {nombre:'Vestimenta',icono:'👔'},{nombre:'Salud',icono:'💊'},
    {nombre:'Otros',icono:'📌'}
  ];
  if (!CONFIG_METS.length) CONFIG_METS = [
    {nombre:'Tarjeta crédito',icono:'💳',tipo:'credito',diaCobro:14},
    {nombre:'Tarjeta débito',icono:'💳',tipo:'debito',diaCobro:0},
    {nombre:'Efectivo',icono:'💵',tipo:'debito',diaCobro:0},
    {nombre:'Transferencia',icono:'🏦',tipo:'debito',diaCobro:0}
  ];
  CATS = CONFIG_CATS.map(c => c.nombre);
  METS = CONFIG_METS.map(m => m.nombre);
}

// ── Lógica de ciclo PRO ───────────────────────────────────
function getRangoCiclo(metodoNombre, mesRef, anioRef) {
  const met = CONFIG_METS.find(m => m.nombre === metodoNombre);
  if (!met || met.tipo !== 'credito' || !met.diaCobro) {
    return { desde: new Date(anioRef, mesRef, 1), hasta: new Date(anioRef, mesRef + 1, 0), label: null };
  }
  const diaCobro = met.diaCobro;
  const desde = new Date(anioRef, mesRef - 1, diaCobro + 1);
  const hasta  = new Date(anioRef, mesRef, diaCobro);
  const fmt = d => d.getDate().toString().padStart(2,'0') + '/' + (d.getMonth()+1).toString().padStart(2,'0');
  return { desde, hasta, label: `Ciclo: ${fmt(desde)} – ${fmt(hasta)}` };
}

function mostrarCicloInfo(metNombre) {
  const infoEl = document.getElementById('ciclo-info');
  if (!infoEl) return;
  const { label } = getRangoCiclo(metNombre, mesSeleccionado, anioSeleccionado);
  if (label) {
    infoEl.textContent = '🔄 ' + label;
    infoEl.style.display = 'block';
  } else {
    infoEl.style.display = 'none';
  }
}

