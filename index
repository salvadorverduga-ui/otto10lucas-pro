function getFavs() { try { return JSON.parse(localStorage.getItem('otto_favs') || '[]'); } catch { return []; } }
function saveFavs(favs) { localStorage.setItem('otto_favs', JSON.stringify(favs)); }

function renderFavs() {
  const wrap = document.getElementById('favs-wrap');
  const favs = getFavs();
  wrap.innerHTML = favs.map((f, i) =>
    `<button class="fav-btn" onclick="aplicarFav(${i})">${f.nombre}<span class="fav-btn-x" onclick="borrarFav(event,${i})">✕</span></button>`
  ).join('') + '<button class="fav-add-btn" onclick="abrirModalFav()">+ Nuevo</button>';
}

function aplicarFav(i) {
  const f = getFavs()[i];
  if (!f) return;
  document.querySelectorAll('#cat-pills .pill').forEach(p => p.classList.toggle('selected', p.dataset.value === f.cat));
  selectedCat = f.cat;
  document.querySelectorAll('#met-pills .pill').forEach(p => p.classList.toggle('selected', p.dataset.value === f.met));
  selectedMet = f.met;
  mostrarCicloInfo(f.met);
  if (f.desc) document.getElementById('reg-desc').value = f.desc;
  document.getElementById('reg-monto').focus();
  mostrarToast('⚡ ' + f.nombre);
}

function borrarFav(e, i) {
  e.stopPropagation();
  const favs = getFavs(); favs.splice(i, 1); saveFavs(favs); renderFavs();
}

function abrirModalFav() { document.getElementById('modal-fav').classList.add('visible'); document.getElementById('fav-nombre').focus(); }
function cerrarModalFav(e) {
  if (!e || e.target === document.getElementById('modal-fav')) {
    document.getElementById('modal-fav').classList.remove('visible');
    document.getElementById('fav-nombre').value = '';
    document.getElementById('fav-desc').value = '';
  }
}
function guardarFav() {
  const nombre = document.getElementById('fav-nombre').value.trim();
  const cat = document.getElementById('fav-cat').value;
  const met = document.getElementById('fav-met').value;
  const desc = document.getElementById('fav-desc').value.trim();
  if (!nombre) { mostrarToast('Escribe un nombre'); return; }
  const favs = getFavs();
  favs.push({ nombre, cat, met, desc });
  saveFavs(favs); renderFavs(); cerrarModalFav(); mostrarToast('Favorito guardado');
}

