async function detalleMetodoPro(metodo) {
  const titleEl = document.getElementById('sheet-title');
  const bodyEl  = document.getElementById('sheet-body');
  titleEl.textContent = metodo;
  try {
    const { desde, hasta, label } = getRangoCiclo(metodo, mesSeleccionado, anioSeleccionado);
    const data = await fetch(urlConMes('historial'), { redirect: 'follow' }).then(r => r.json());
    const items = data.filter(r => {
      if (r.tipo === 'ingreso' || r.metodo !== metodo) return false;
      const partes = r.fecha.split('/');
      const d = new Date(anioSeleccionado, parseInt(partes[1])-1, parseInt(partes[0]));
      return d >= desde && d <= hasta;
    });
    const cicloInfo = label ? `<div style="color:var(--accent);font-size:11px;margin-bottom:12px;">🔄 ${label}</div>` : '';
    if (!items.length) { bodyEl.innerHTML = cicloInfo + `<span style="color:var(--muted);font-size:13px;">Sin gastos con ${metodo} este período.</span>`; return; }
    const total = items.reduce((s, r) => s + parseFloat(r.monto), 0);
    bodyEl.innerHTML = cicloInfo + items.map(r =>
      `<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #1a1a1a;font-size:13px;">
        <div><div style="color:var(--text);">${r.descripcion}</div><div style="color:var(--muted);font-size:11px;">${r.fecha} · ${r.categoria}</div></div>
        <span style="color:var(--expense);font-weight:600;">$${r.monto}</span>
      </div>`
    ).join('') +
    `<div style="border-top:1px solid #2a2a2a;margin-top:8px;padding-top:10px;display:flex;justify-content:space-between;">
      <span style="color:var(--muted);font-size:11px;">Total</span>
      <span style="color:#fff;font-size:15px;font-weight:700;">$${total.toFixed(2)}</span>
    </div>`;
  } catch { bodyEl.innerHTML = '<span class="error">Error al cargar.</span>'; }
}

