async function detalleCat(cat) {
  const titleEl = document.getElementById('sheet-title');
  const bodyEl  = document.getElementById('sheet-body');
  titleEl.textContent = cat;
  try {
    const url = scriptUrl + '?cmd=detalle_cat&cat=' + encodeURIComponent(cat) + '&mes=' + mesSeleccionado + '&anio=' + anioSeleccionado;
    const res  = await fetch(url, { redirect: 'follow' });
    const data = await res.json();
    if (!data.bloques) { bodyEl.textContent = 'Sin datos.'; return; }
    let html = `<div style="font-size:13px;color:var(--accent);font-weight:700;margin-bottom:12px;">${data.categoria} — ${data.mes}</div>`;
    let hayDatos = false;
    data.bloques.forEach(bloque => {
      if (!bloque.items.length) return;
      hayDatos = true;
      html += `<div style="margin-bottom:14px;"><div style="color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;">${bloque.titulo}</div>`;
      bloque.items.forEach(item => {
        html += `<div style="display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid #1a1a1a;gap:8px;">
          <span style="color:var(--muted);font-size:11px;flex-shrink:0;">${item.fecha}</span>
          <span style="color:var(--text);flex:1;font-size:13px;">${item.descripcion}</span>
          <span style="color:var(--expense);font-size:13px;font-weight:600;">$${item.monto}</span></div>`;
      });
      html += `<div style="text-align:right;font-size:11px;color:var(--text-sub);margin-top:6px;">Subtotal: <strong style="color:var(--text);">$${bloque.total}</strong></div></div>`;
    });
    if (!hayDatos) { bodyEl.innerHTML = `<span style="color:var(--muted);font-size:13px;">Sin gastos de ${cat} este mes.</span>`; return; }
    html += `<div style="border-top:1px solid #2a2a2a;margin-top:4px;padding-top:10px;display:flex;justify-content:space-between;align-items:center;"><span style="color:var(--muted);font-size:11px;text-transform:uppercase;">Total</span><span style="color:#fff;font-size:16px;font-weight:700;">$${data.total}</span></div>`;
    bodyEl.innerHTML = html;
  } catch { bodyEl.innerHTML = '<span class="error">Error al cargar.</span>'; }
}

