async function cargarSuscripciones() {
  const lista = document.getElementById('suscripciones-lista');
  lista.innerHTML = '<p style="color:var(--muted);font-size:13px;">Cargando...</p>';
  try {
    const data = await fetch(scriptUrl + '?cmd=suscripciones_detalle', { redirect: 'follow' }).then(r => r.json());
    if (!data.length) { lista.innerHTML = '<p class="empty-state">Sin suscripciones registradas.</p>'; return; }
    const hoy = new Date().getDate();
    lista.innerHTML = data.map(s => {
      const diasFaltantes = s.dia - hoy;
      const alerta = diasFaltantes >= 0 && diasFaltantes <= 7;
      return `<div class="sub-item ${alerta ? 'alerta' : ''}">
        <div class="sub-info">
          <div class="sub-nombre">${s.nombre} ${alerta ? '<span class="sub-alerta-badge">⚠️ ' + (diasFaltantes === 0 ? 'Hoy' : 'en ' + diasFaltantes + 'd') + '</span>' : ''}</div>
          <div class="sub-meta">${s.categoria || ''} · ${s.metodo || ''} ${s.notas ? '· ' + s.notas : ''}</div>
        </div>
        <div class="sub-derecha">
          <div class="sub-monto">$${parseFloat(s.monto).toFixed(2)}</div>
          <div class="sub-dia">Día ${s.dia}</div>
          <button class="sub-del-btn" onclick="eliminarSuscripcion(${s.fila})">🗑</button>
        </div>
      </div>`;
    }).join('');
    // Total al final
    const total = data.reduce((s, x) => s + parseFloat(x.monto), 0);
    lista.innerHTML += `<div style="border-top:1px solid var(--card-brd);margin-top:8px;padding-top:12px;display:flex;justify-content:space-between;font-size:13px;"><span style="color:var(--muted);">Total mensual</span><strong style="color:var(--expense);">$${total.toFixed(2)}</strong></div>`;
  } catch { lista.innerHTML = '<p class="error">Error al cargar.</p>'; }
}

