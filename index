// ── Cola offline ──────────────────────────────────────────
function getCola() { try { return JSON.parse(localStorage.getItem('otto_cola') || '[]'); } catch { return []; } }
function saveCola(cola) { try { localStorage.setItem('otto_cola', JSON.stringify(cola)); } catch {} }

function encolarGasto(paramsStr) {
  const cola = getCola();
  cola.push({ id: Date.now(), paramsStr, ts: new Date().toISOString() });
  saveCola(cola); actualizarBadgeCola();
}

function actualizarBadgeCola() {
  const cola  = getCola();
  const badge = document.getElementById('cola-badge');
  if (!badge) return;
  if (cola.length > 0) { badge.textContent = '📤 ' + cola.length + ' pendiente' + (cola.length > 1 ? 's' : ''); badge.classList.add('visible'); }
  else badge.classList.remove('visible');
}

async function reintentarCola() {
  const cola = getCola();
  if (!cola.length) return;
  mostrarToast('Enviando pendientes...');
  const fallidos = [];
  for (const item of cola) {
    try {
      const res = await fetch(scriptUrl + '?' + item.paramsStr, { redirect: 'follow' });
      const txt = await res.text();
      if (!txt.includes('✅')) fallidos.push(item);
    } catch { fallidos.push(item); }
  }
  saveCola(fallidos); actualizarBadgeCola();
  mostrarToast(fallidos.length === 0 ? '✅ ' + cola.length + ' gasto' + (cola.length > 1 ? 's enviados' : ' enviado') : '⚠️ ' + fallidos.length + ' sin enviar');
}

window.addEventListener('online', () => { if (getCola().length > 0) reintentarCola(); });
window.addEventListener('load', actualizarBadgeCola);

