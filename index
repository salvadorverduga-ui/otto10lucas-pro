function setTipoReg(tipo) {
  tipoReg = tipo;
  document.getElementById('toggle-gasto').className   = 'reg-toggle-btn' + (tipo === 'gasto' ? ' active-expense' : '');
  document.getElementById('toggle-ingreso').className = 'reg-toggle-btn' + (tipo === 'ingreso' ? ' active-income' : '');
  document.getElementById('campos-gasto').style.display   = tipo === 'gasto' ? 'block' : 'none';
  document.getElementById('campos-ingreso').style.display = tipo === 'ingreso' ? 'block' : 'none';
  document.getElementById('favs-section').style.display   = tipo === 'gasto' ? 'block' : 'none';
  const btn = document.getElementById('submit-btn');
  btn.textContent = tipo === 'gasto' ? 'Registrar gasto' : 'Registrar ingreso';
  btn.className = 'submit-btn' + (tipo === 'ingreso' ? ' income-btn' : '');
}

async function registrar() {
  const fecha = document.getElementById('reg-fecha').value;
  const monto = document.getElementById('reg-monto').value.replace(',', '.');
  const desc  = document.getElementById('reg-desc').value.trim();
  const btn   = document.getElementById('submit-btn');
  let params;
  if (tipoReg === 'gasto') {
    if (!fecha || !monto || !selectedCat || !selectedMet || !desc) { mostrarToast('Completa todos los campos'); return; }
    params = new URLSearchParams({ cmd: 'registrar', fecha, monto, categoria: selectedCat, metodo: selectedMet, descripcion: desc });
  } else {
    const fuente = document.getElementById('reg-fuente').value;
    if (!fecha || !monto || !fuente || !desc) { mostrarToast('Completa todos los campos'); return; }
    params = new URLSearchParams({ cmd: 'registrar_ingreso', fecha, monto, fuente, descripcion: desc });
  }
  btn.textContent = 'Registrando...'; btn.disabled = true;
  try {
    const res = await fetch(scriptUrl + '?' + params.toString(), { redirect: 'follow' });
    mostrarToast(await res.text());
    limpiarFormRegistrar();
  } catch {
    encolarGasto(params.toString());
    mostrarToast('📥 Sin conexión — guardado para enviar después');
    limpiarFormRegistrar();
  }
  btn.textContent = tipoReg === 'gasto' ? 'Registrar gasto' : 'Registrar ingreso';
  btn.disabled = false;
}

function limpiarFormRegistrar() {
  document.getElementById('reg-monto').value = '';
  document.getElementById('reg-desc').value  = '';
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('selected'));
  selectedCat = ''; selectedMet = '';
  document.getElementById('ciclo-info').style.display = 'none';
  if (document.getElementById('reg-fuente')) document.getElementById('reg-fuente').value = '';
}

// ── Historial ─────────────────────────────────────────────
function setFiltroHist(filtro) {
  filtroActivo = filtro;
  document.querySelectorAll('.hist-filter-btn').forEach(btn => {
    const onclick = btn.getAttribute('onclick') || '';
    btn.classList.toggle('active', onclick.includes("'" + filtro + "'") || onclick.includes('"' + filtro + '"'));
  });
  aplicarFiltroHist();
}

function aplicarFiltroHist() {
  const totalEl = document.getElementById('hist-filter-total');
  const labelEl = document.getElementById('hist-filter-label');
  const sumEl   = document.getElementById('hist-filter-sum');
  let visibles = 0, suma = 0;
  document.querySelectorAll('.historial-item').forEach(el => {
    const cat    = el.dataset.categoria || '';
    const metodo = el.dataset.metodo   || '';
    const match  = filtroActivo === 'todos' || cat === filtroActivo || metodo === filtroActivo;
    el.style.display = match ? 'block' : 'none';
    if (match) { visibles++; suma += parseFloat(el.dataset.monto || 0); }
  });
  if (filtroActivo !== 'todos') {
    totalEl.classList.add('visible');
    labelEl.textContent = visibles + ' registro' + (visibles !== 1 ? 's' : '') + ' · ' + filtroActivo;
    sumEl.textContent   = '$' + suma.toFixed(2);
  } else { totalEl.classList.remove('visible'); }
}

async function cargarHistorial() {
  const lista = document.getElementById('historial-lista');
  function render(data, fromCache, ts) {
    if (!data.length) { lista.innerHTML = '<p style="color:var(--muted);font-size:13px;">No hay registros.</p>'; return; }
    const badge = fromCache ? `<div style="margin-bottom:10px;"><span class="cache-badge">📦 ${formatTs(ts)}</span></div>` : '';
    lista.innerHTML = badge + data.map(r => {
      const montoClass = r.tipo === 'ingreso' ? 'ingreso' : 'gasto';
      const prefix     = r.tipo === 'ingreso' ? '+' : '-';
      return `<div class="historial-item" id="item-${r.fila}" data-categoria="${(r.categoria||'').replace(/"/g,'&quot;')}" data-metodo="${(r.metodo||'').replace(/"/g,'&quot;')}" data-monto="${r.monto}">
        <div class="historial-vista">
          <div class="historial-info">
            <div class="historial-fecha">${r.fecha}</div>
            <div class="historial-desc">${r.descripcion}</div>
            <div class="historial-meta">${r.categoria} · ${r.metodo || ''}</div>
          </div>
          <div class="historial-monto ${montoClass}">${prefix}$${r.monto}</div>
        </div>
        <div class="historial-acciones">
          <button class="edit-btn" onclick="toggleEdit(${r.fila})">✏️</button>
          <button class="repeat-btn" onclick="repetirGasto(${r.fila})">🔁</button>
          <button class="delete-btn" onclick="eliminar(${r.fila})">🗑</button>
        </div>
        <div class="historial-form" id="form-${r.fila}">
          <input class="h-input" type="date" id="e-fecha-${r.fila}" value="${fechaAInput(r.fecha)}" />
          <input class="h-input" type="text" id="e-monto-${r.fila}" value="${r.monto}" inputmode="decimal" placeholder="Monto" />
          <select class="h-select" id="e-cat-${r.fila}">${CATS.map(c => `<option value="${c}" ${c===r.categoria?'selected':''}>${c}</option>`).join('')}</select>
          <select class="h-select" id="e-met-${r.fila}">${METS.map(m => `<option value="${m}" ${m===(r.metodo||'')?'selected':''}>${m}</option>`).join('')}</select>
          <input class="h-input" type="text" id="e-desc-${r.fila}" value="${r.descripcion}" placeholder="Descripción" />
          <div class="h-btns">
            <button class="save-edit-btn" onclick="guardarEdicion(${r.fila})">Guardar</button>
            <button class="cancel-edit-btn" onclick="toggleEdit(${r.fila})">Cancelar</button>
          </div>
        </div>
      </div>`;
    }).join('');
    aplicarFiltroHist();
  }
  const cached = leerCache('historial');
  if (cached) { historialData = cached.data; render(cached.data, true, cached.ts); }
  else lista.innerHTML = '<p style="color:var(--muted);font-size:13px;">Cargando...</p>';
  try {
    const res  = await fetch(urlConMes('historial'), { redirect: 'follow' });
    const data = await res.json();
    guardarCache('historial', data); historialData = data; render(data, false, null);
    mostrarOfflineBanner(false);
  } catch {
    if (cached) mostrarOfflineBanner(true);
    else lista.innerHTML = '<p class="error">Sin conexión.</p>';
  }
}

function repetirGasto(fila) {
  const r = historialData.find(x => x.fila === fila);
  if (!r) return;
  switchTab('registrar');
  setFechaRapida(0);
  document.getElementById('reg-monto').value = r.monto;
  document.getElementById('reg-desc').value  = r.descripcion;
  document.querySelectorAll('#cat-pills .pill').forEach(p => p.classList.toggle('selected', p.dataset.value === r.categoria));
  selectedCat = r.categoria;
  document.querySelectorAll('#met-pills .pill').forEach(p => p.classList.toggle('selected', p.dataset.value === (r.metodo||'')));
  selectedMet = r.metodo || '';
  mostrarCicloInfo(selectedMet);
  setTipoReg('gasto');
  mostrarToast('🔁 ' + r.descripcion);
  setTimeout(() => document.getElementById('reg-monto').focus(), 300);
}

function fechaAInput(fecha) {
  const p = fecha.split('/');
  if (p.length === 3) return p[2] + '-' + p[1] + '-' + p[0];
  return new Date().getFullYear() + '-' + p[1] + '-' + p[0];
}
function toggleEdit(fila) { document.getElementById('form-' + fila).classList.toggle('visible'); }

async function guardarEdicion(fila) {
  const fecha       = document.getElementById('e-fecha-' + fila).value;
  const monto       = document.getElementById('e-monto-' + fila).value.replace(',', '.');
  const categoria   = document.getElementById('e-cat-' + fila).value;
  const metodo      = document.getElementById('e-met-' + fila).value;
  const descripcion = document.getElementById('e-desc-' + fila).value.trim();
  if (!fecha || !monto || !categoria || !metodo || !descripcion) { mostrarToast('Completa todos los campos'); return; }
  const params = new URLSearchParams({ cmd: 'editar', fila, fecha, monto, categoria, metodo, descripcion });
  try { const res = await fetch(scriptUrl + '?' + params.toString(), { redirect: 'follow' }); mostrarToast(await res.text()); cargarHistorial(); }
  catch { mostrarToast('Error al guardar'); }
}

async function eliminar(fila) {
  if (!confirm('¿Eliminar?')) return;
  try { const res = await fetch(scriptUrl + '?cmd=eliminar&fila=' + fila, { redirect: 'follow' }); mostrarToast(await res.text()); document.getElementById('item-' + fila)?.remove(); }
  catch { mostrarToast('Error al eliminar'); }
}

// ── Gráfico ───────────────────────────────────────────────
async function cargarGrafico() {
  const legend = document.getElementById('legend-body');
  const colores = ['#4e9a6f','#e8a838','#e05252','#5b8fe8','#9b6fe8','#e87d5b','#50b4b4','#d47fc0','#e8c870','#7fd4a0','#c4a46a','#8080d4'];
  function renderGrafico(data, fromCache, ts) {
    let categorias = [], sueldo = 0;
    if (Array.isArray(data)) categorias = data;
    else if (data.gastos) { categorias = data.gastos; sueldo = data.sueldo || 0; }
    const labels = categorias.map(d => d.nombre);
    const valores = categorias.map(d => d.valor);
    const total = valores.reduce((a,b) => a+b, 0);
    if (sueldo > 0) {
      const pct = Math.min((total/sueldo)*100, 100);
      const fill = document.getElementById('budget-fill');
      fill.style.width = pct + '%';
      fill.className = 'budget-bar-fill' + (pct >= 90 ? ' danger' : pct >= 70 ? ' warn' : '');
      document.getElementById('budget-nums').innerHTML = `<strong>$${total.toFixed(2)}</strong> / $${sueldo.toFixed(2)}`;
      document.getElementById('budget-spent').textContent = `Gastado: $${total.toFixed(2)} (${Math.round(pct)}%)`;
      document.getElementById('budget-left').textContent  = `Disponible: $${(sueldo-total).toFixed(2)}`;
    }
    if (chartInstance) chartInstance.destroy();
    const ctx = document.getElementById('donaChart').getContext('2d');
    chartInstance = new Chart(ctx, {
      type: 'doughnut',
      data: { labels, datasets: [{ data: valores, backgroundColor: colores, borderWidth: 0 }] },
      options: { plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => ' $' + c.parsed.toFixed(2) + ' (' + Math.round(c.parsed/total*100) + '%)' } } }, cutout: '60%' }
    });
    const badge = fromCache ? `<div><span class="cache-badge">📦 ${formatTs(ts)}</span></div>` : '';
    legend.innerHTML = badge + categorias.map((d,i) =>
      `<div class="legend-item"><span class="legend-dot" style="background:${colores[i%colores.length]}"></span>${d.nombre}: <strong style="color:var(--text);margin-left:4px;">$${d.valor}</strong> <span style="color:var(--muted);">(${Math.round(d.valor/total*100)}%)</span></div>`
    ).join('');
  }
  const cached = leerCache('chart');
  if (cached) renderGrafico(cached.data, true, cached.ts);
  else legend.textContent = 'Cargando...';
  try {
    const res  = await fetch(urlConMes('chart'), { redirect: 'follow' });
    const data = await res.json();
    guardarCache('chart', data); renderGrafico(data, false, null);
  } catch { if (!cached) legend.textContent = 'Sin conexión.'; }
}

