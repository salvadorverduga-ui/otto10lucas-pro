<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Otto y 10 lucas — Pro</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
/* ══════════════════════════════════════════════════════════
   TEMAS — Otto y 10 lucas PRO
   ══════════════════════════════════════════════════════════ */

/* ── Tema 1: Obsidian & Gold (predeterminado) ── */
:root {
  --bg:          #0d0b08;
  --card:        #1a1710;
  --card-brd:    #2a2518;
  --card-deep:   #120f08;
  --nav-bg:      #111008;
  --nav-brd:     #1e1a10;
  --sheet-bg:    #141108;
  --input-bg:    #0e0c06;
  --accent:      #c9a84c;
  --accent-dim:  #1e1a0a;
  --accent-brd:  #3a2e10;
  --accent-deep: #2a200a;
  --text:        #ede8d8;
  --text-sub:    #888070;
  --muted:       #5a5040;
  --expense:     #c47a5a;
  --income:      #7aa8c4;
  --warn:        #e8a838;
  --danger:      #e05252;
}

/* ── Tema 2: Forest ── */
[data-theme="forest"] {
  --bg:          #0a0a0a;
  --card:        #1a1a1a;
  --card-brd:    #2a2a2a;
  --card-deep:   #111111;
  --nav-bg:      #111111;
  --nav-brd:     #1e1e1e;
  --sheet-bg:    #141414;
  --input-bg:    #111111;
  --accent:      #7fd4a0;
  --accent-dim:  #1a3a2a;
  --accent-brd:  #2a5a3a;
  --accent-deep: #111e16;
  --text:        #e0e0e0;
  --text-sub:    #888888;
  --muted:       #555555;
  --expense:     #e07070;
  --income:      #7fb4d4;
  --warn:        #e8a838;
  --danger:      #e05252;
}

/* ── Tema 3: Arctic Slate ── */
[data-theme="arctic"] {
  --bg:          #090c10;
  --card:        #111620;
  --card-brd:    #1e2635;
  --card-deep:   #0d1018;
  --nav-bg:      #0d1018;
  --nav-brd:     #1a2030;
  --sheet-bg:    #101520;
  --input-bg:    #0a0e16;
  --accent:      #5ba8c4;
  --accent-dim:  #0a1520;
  --accent-brd:  #1a3a50;
  --accent-deep: #0a1828;
  --text:        #d8e8f0;
  --text-sub:    #607080;
  --muted:       #405060;
  --expense:     #c46a7a;
  --income:      #7ac4a0;
  --warn:        #e8a838;
  --danger:      #e05252;
}

/* ── Tema 4 PRO EXCLUSIVO: Sakura Dark ── */
[data-theme="sakura"] {
  --bg:          #080608;
  --card:        #110d11;
  --card-brd:    #201520;
  --card-deep:   #0d090d;
  --nav-bg:      #0d090d;
  --nav-brd:     #1a101a;
  --sheet-bg:    #100c10;
  --input-bg:    #0a070a;
  --accent:      #e87aaa;
  --accent-dim:  #20101a;
  --accent-brd:  #401828;
  --accent-deep: #180c14;
  --text:        #ffffff;
  --text-sub:    #906080;
  --muted:       #504050;
  --expense:     #e87aaa;
  --income:      #80d4c0;
  --warn:        #e8c870;
  --danger:      #f05070;
}

/* ── Selector de temas ── */
.theme-picker { display: flex; gap: 16px; align-items: center; justify-content: center; margin-top: 20px; }
.theme-dot { width: 28px; height: 28px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: transform 0.15s, border-color 0.15s; -webkit-tap-highlight-color: transparent; }
.theme-dot:active { transform: scale(0.88); }
.theme-dot.active { border-color: var(--text); transform: scale(1.15); }
.theme-dot-obsidian { background: radial-gradient(circle at 35% 35%, #e8c86a, #8a6020); }
.theme-dot-forest   { background: radial-gradient(circle at 35% 35%, #9fe4b8, #2a7a50); }
.theme-dot-arctic   { background: radial-gradient(circle at 35% 35%, #80c8e0, #204868); }
.theme-dot-sakura   { background: radial-gradient(circle at 35% 35%, #f0b0d0, #801040); }
.theme-dot-sakura::after { content: '✦'; position: absolute; font-size: 8px; color: gold; top: -4px; right: -4px; }
.theme-dot-sakura { position: relative; }

* { box-sizing: border-box; margin: 0; padding: 0; }

/* ── BASE ── */
body {
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg); color: var(--text);
  min-height: 100vh;
  padding: 16px 16px 80px;
}

/* ── HEADER ── */
.header { text-align: center; padding: 16px 0 20px; }
.header h1 { font-size: 22px; font-weight: 600; cursor: pointer; -webkit-tap-highlight-color: transparent; }
.header h1:active { opacity: 0.7; }
.header p { color: var(--muted); font-size: 13px; margin-top: 4px; }
.connected { color: var(--accent); font-size: 12px; }
.pro-badge { display: inline-block; background: var(--accent-dim); border: 1px solid var(--accent-brd); color: var(--accent); font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; margin-left: 6px; vertical-align: middle; letter-spacing: 0.5px; }

/* ── CONFIG ── */
.config { background: var(--card); border-radius: 12px; padding: 14px; margin-bottom: 20px; border: 1px solid var(--card-brd); }
.config label { color: var(--text-sub); font-size: 11px; display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
.config input { background: var(--input-bg); border: 1px solid var(--card-brd); border-radius: 8px; color: #fff; font-size: 13px; padding: 10px 12px; width: 100%; outline: none; }
.save-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 8px; color: var(--accent); font-size: 14px; padding: 10px; margin-top: 10px; cursor: pointer; width: 100%; font-weight: 500; }

/* ── MONTH BAR ── */
.month-bar { display: flex; align-items: center; gap: 8px; background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 10px 14px; margin-bottom: 16px; }
.month-bar label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; flex-shrink: 0; }
.month-select { background: transparent; border: none; color: var(--accent); font-size: 14px; font-weight: 600; outline: none; cursor: pointer; flex: 1; appearance: none; -webkit-appearance: none; }
.month-select option { background: var(--card); color: #fff; }
.month-arrow { color: var(--muted); font-size: 12px; pointer-events: none; }

/* ── BOTTOM NAV ── */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--nav-bg); border-top: 1px solid var(--nav-brd);
  display: flex; z-index: 50; padding-bottom: env(safe-area-inset-bottom);
}
.nav-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 10px 4px 8px; cursor: pointer; -webkit-tap-highlight-color: transparent;
  color: var(--muted); font-size: 10px; gap: 4px;
}
.nav-item .nav-icon { font-size: 20px; }
.nav-item.active { color: var(--accent); }
.nav-item.nav-plus .nav-icon {
  background: var(--accent-dim); border: 1px solid var(--accent-brd);
  border-radius: 50%; width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; margin-top: -6px;
}

/* ── PAGES ── */
.page { display: none; }
.page.active { display: block; }

/* ── HOME ── */
.home-balance {
  background: linear-gradient(135deg, var(--accent-deep), var(--card-deep));
  border: 1px solid var(--accent-brd); border-radius: 16px;
  padding: 20px; margin-bottom: 14px; text-align: center;
}
.home-balance-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
.home-balance-val { font-size: 38px; font-weight: 700; color: var(--accent); }
.home-balance-val.warn { color: #e8a838; }
.home-balance-val.danger { color: #e05252; }
.home-balance-sub { display: flex; justify-content: center; gap: 20px; margin-top: 10px; font-size: 12px; }
.home-balance-sub span { color: var(--muted); }
.home-balance-sub .inc { color: var(--income); }
.home-balance-sub .exp { color: var(--expense); }
.home-hoy { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 14px; margin-bottom: 14px; }
.home-hoy-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.home-hoy-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
.home-hoy-total { font-size: 15px; font-weight: 700; color: var(--expense); }
.home-hoy-item { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 1px solid #1a1a1a; font-size: 13px; }
.home-hoy-item:last-child { border-bottom: none; }
.home-hoy-desc { color: var(--text); flex: 1; }
.home-hoy-meta { color: var(--muted); font-size: 11px; margin-right: 8px; }
.home-hoy-monto { color: var(--expense); font-weight: 600; }
.home-hoy-empty { color: var(--muted); font-size: 13px; font-style: italic; }

/* ── IMPACTO PRÓXIMO MES (PRO) ── */
.impacto-card { background: var(--card); border: 1px solid var(--accent-brd); border-radius: 12px; padding: 14px; margin-bottom: 14px; cursor: pointer; -webkit-tap-highlight-color: transparent; }
.impacto-header { display: flex; justify-content: space-between; align-items: center; }
.impacto-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
.impacto-total { font-size: 16px; font-weight: 700; color: var(--warn); }
.impacto-arrow { color: var(--muted); font-size: 14px; }
.impacto-desglose { display: none; margin-top: 10px; border-top: 1px solid var(--card-brd); padding-top: 10px; font-size: 12px; }
.impacto-desglose.visible { display: block; }
.impacto-row { display: flex; justify-content: space-between; padding: 3px 0; color: var(--text-sub); }
.impacto-row strong { color: var(--text); }

/* ── SECTIONS / BUTTONS ── */
.section { margin-bottom: 20px; }
.section-title { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; padding-left: 2px; }
.btn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.btn-grid.three { grid-template-columns: 1fr 1fr 1fr; }
.btn { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 14px 8px; color: #fff; font-size: 13px; font-weight: 500; cursor: pointer; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 6px; -webkit-tap-highlight-color: transparent; }
.btn:active { background: #252525; transform: scale(0.97); }
.btn .icon { font-size: 22px; }
.btn .label { font-size: 11px; color: var(--text-sub); font-weight: 400; }
.btn.green { border-color: #2a5a3a; background: var(--accent-deep); }
.btn.amber { border-color: #3a2a0a; background: var(--accent-dim); }
.btn.pro { border-color: var(--accent-brd); background: var(--accent-dim); }

/* ── BOTTOM SHEET ── */
.sheet-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.6);
  z-index: 60; display: none; align-items: flex-end;
}
.sheet-overlay.visible { display: flex; }
.sheet-panel {
  background: var(--sheet-bg); border-radius: 20px 20px 0 0;
  border-top: 1px solid var(--card-brd);
  width: 100%; max-height: 85vh;
  overflow-y: auto; padding: 0 16px 32px;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.sheet-overlay.visible .sheet-panel { transform: translateY(0); }
.sheet-handle { width: 36px; height: 4px; background: #333; border-radius: 2px; margin: 12px auto 16px; }
.sheet-title { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 14px; }
.sheet-body { color: var(--text); font-size: 14px; line-height: 1.7; white-space: pre-wrap; }
.loading { color: var(--muted); font-style: italic; }
.error { color: #e24b4a; }

/* ── REGISTRAR ── */
.reg-toggle { display: flex; gap: 6px; margin-bottom: 18px; }
.reg-toggle-btn { flex: 1; padding: 10px; border-radius: 10px; font-size: 13px; font-weight: 600; cursor: pointer; text-align: center; border: 1px solid var(--card-brd); background: var(--card); color: var(--text-sub); }
.reg-toggle-btn.active-expense { border-color: #5a2a2a; color: var(--expense); }
.reg-toggle-btn.active-income { background: #1a2a3a; border-color: #2a4a6a; color: var(--income); }

/* Favoritos */
.favs-section { margin-bottom: 18px; }
.favs-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.favs-wrap { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.fav-btn { background: var(--accent-deep); border: 1px solid var(--accent-brd); border-radius: 20px; color: var(--accent); font-size: 12px; padding: 7px 10px 7px 14px; cursor: pointer; -webkit-tap-highlight-color: transparent; white-space: nowrap; display: inline-flex; align-items: center; gap: 6px; }
.fav-btn:active { transform: scale(0.96); }
.fav-btn-x { color: var(--muted); font-size: 14px; line-height: 1; padding: 0 2px; -webkit-tap-highlight-color: transparent; }
.fav-btn-x:active { color: var(--expense); }
.fav-add-btn { background: var(--card); border: 1px dashed var(--card-brd); border-radius: 20px; color: var(--muted); font-size: 12px; padding: 7px 14px; cursor: pointer; }

/* Fecha rápida */
.fecha-rapida { display: flex; gap: 6px; margin-bottom: 8px; }
.fecha-btn { background: var(--card); border: 1px solid var(--card-brd); border-radius: 8px; color: var(--text-sub); font-size: 12px; padding: 6px 12px; cursor: pointer; flex: 1; text-align: center; }
.fecha-btn.active { background: var(--accent-dim); border-color: var(--accent-brd); color: var(--accent); }

.form-field { margin-bottom: 14px; }
.form-field label { color: var(--text-sub); font-size: 11px; display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
.form-field input, .form-field select { background: var(--input-bg); border: 1px solid var(--card-brd); border-radius: 8px; color: #fff; font-size: 15px; padding: 12px; width: 100%; outline: none; }
.form-field select option { background: var(--card); }
.pill-group { display: flex; flex-wrap: wrap; gap: 8px; }
.pill { background: var(--card); border: 1px solid var(--card-brd); border-radius: 20px; padding: 8px 14px; color: var(--text-sub); font-size: 13px; cursor: pointer; -webkit-tap-highlight-color: transparent; }
.pill.selected { background: var(--accent-dim); border-color: var(--accent-brd); color: var(--accent); }
.submit-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 12px; color: var(--accent); font-size: 15px; font-weight: 600; padding: 16px; width: 100%; cursor: pointer; margin-top: 8px; }
.submit-btn:active { transform: scale(0.98); }
.submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.submit-btn.income-btn { background: #1a2a3a; border-color: #2a4a6a; color: var(--income); }

/* ── HISTORIAL ── */
.hist-filter-wrap { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; overflow-x: auto; padding-bottom: 4px; }
.hist-filter-btn { background: var(--card); border: 1px solid var(--card-brd); border-radius: 20px; color: var(--text-sub); font-size: 12px; padding: 6px 12px; cursor: pointer; -webkit-tap-highlight-color: transparent; white-space: nowrap; }
.hist-filter-btn.active { background: var(--accent-dim); border-color: var(--accent-brd); color: var(--accent); }
.hist-filter-total { background: var(--accent-deep); border: 1px solid var(--accent-brd); border-radius: 10px; padding: 8px 14px; margin-bottom: 10px; display: none; font-size: 13px; }
.hist-filter-total.visible { display: flex; justify-content: space-between; align-items: center; }
.historial-item { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 12px 14px; margin-bottom: 8px; }
.historial-vista { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
.historial-info { flex: 1; }
.historial-fecha { color: var(--muted); font-size: 11px; margin-bottom: 3px; }
.historial-desc { color: var(--text); font-size: 14px; font-weight: 500; }
.historial-meta { color: var(--text-sub); font-size: 11px; margin-top: 2px; }
.historial-monto { font-size: 15px; font-weight: 600; white-space: nowrap; }
.historial-monto.gasto { color: var(--expense); }
.historial-monto.ingreso { color: var(--income); }
.historial-acciones { display: flex; gap: 6px; margin-top: 8px; }
.edit-btn { background: #1a2a3a; border: 1px solid #2a4a5a; border-radius: 8px; color: var(--income); font-size: 12px; padding: 6px 10px; cursor: pointer; flex: 1; }
.delete-btn { background: #2a1a1a; border: 1px solid #5a2a2a; border-radius: 8px; color: #e24b4a; font-size: 12px; padding: 6px 10px; cursor: pointer; flex: 1; }
.repeat-btn { background: #1a1a2a; border: 1px solid #2a2a5a; border-radius: 8px; color: #9b9bd4; font-size: 12px; padding: 6px 10px; cursor: pointer; flex: 1; }
.historial-form { display: none; margin-top: 10px; border-top: 1px solid var(--card-brd); padding-top: 10px; }
.historial-form.visible { display: block; }
.h-input { background: var(--input-bg); border: 1px solid var(--card-brd); border-radius: 8px; color: #fff; font-size: 13px; padding: 8px 10px; width: 100%; outline: none; margin-bottom: 8px; }
.h-select { background: var(--input-bg); border: 1px solid var(--card-brd); border-radius: 8px; color: #fff; font-size: 13px; padding: 8px 10px; width: 100%; outline: none; margin-bottom: 8px; }
.h-btns { display: flex; gap: 8px; }
.save-edit-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 8px; color: var(--accent); font-size: 13px; padding: 10px; cursor: pointer; flex: 1; font-weight: 500; }
.cancel-edit-btn { background: var(--card); border: 1px solid var(--card-brd); border-radius: 8px; color: var(--text-sub); font-size: 13px; padding: 10px; cursor: pointer; flex: 1; }
.refresh-btn { background: var(--card); border: 1px solid var(--card-brd); border-radius: 10px; color: var(--text-sub); font-size: 13px; padding: 10px; width: 100%; cursor: pointer; margin-bottom: 12px; }
input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1); }

/* ── ANÁLISIS ── */
.analisis-menu { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
.analisis-item { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 14px 16px; cursor: pointer; display: flex; align-items: center; gap: 12px; -webkit-tap-highlight-color: transparent; }
.analisis-item:active { background: #222; }
.analisis-icon { font-size: 22px; }
.analisis-text { flex: 1; }
.analisis-text strong { font-size: 14px; color: var(--text); display: block; }
.analisis-text span { font-size: 12px; color: var(--muted); }
.analisis-arrow { color: #333; font-size: 16px; }
.sub-page { display: none; }
.sub-page.active { display: block; }
.back-btn { background: none; border: none; color: var(--accent); font-size: 13px; padding: 0 0 14px; cursor: pointer; display: flex; align-items: center; gap: 6px; }

/* ── CHART ── */
.chart-container { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 16px; margin-bottom: 16px; }
.chart-title { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; }
.legend-item { display: flex; align-items: center; gap: 6px; padding: 4px 0; font-size: 13px; }
.legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

/* ── BUDGET BARS ── */
.budget-bar-wrap { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 16px; margin-bottom: 16px; }
.budget-bar-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
.budget-bar-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
.budget-bar-nums { font-size: 12px; color: var(--text-sub); }
.budget-bar-nums strong { color: var(--text); }
.budget-bar-track { background: var(--input-bg); border-radius: 20px; height: 12px; overflow: hidden; }
.budget-bar-fill { height: 100%; border-radius: 20px; background: linear-gradient(90deg, var(--accent-dim), var(--accent)); transition: width 0.5s ease; }
.budget-bar-fill.warn { background: linear-gradient(90deg, #e8a838, #f5c870); }
.budget-bar-fill.danger { background: linear-gradient(90deg, #e05252, #f08080); }
.budget-bar-sub { display: flex; justify-content: space-between; margin-top: 8px; font-size: 11px; }
.budget-bar-spent { color: #e24b4a; }
.budget-bar-left { color: var(--accent); }

/* ── HISTÓRICO / COMPARAR ── */
.hist-toggle { display: flex; gap: 6px; margin-bottom: 16px; }
.hist-toggle-btn { flex: 1; padding: 9px; border-radius: 10px; font-size: 12px; font-weight: 600; cursor: pointer; text-align: center; border: 1px solid var(--card-brd); background: var(--card); color: var(--text-sub); }
.hist-toggle-btn.active { background: var(--accent-dim); border-color: var(--accent-brd); color: var(--accent); }
.comp-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 8px; color: var(--accent); font-size: 13px; font-weight: 600; padding: 10px 14px; cursor: pointer; white-space: nowrap; }
.comp-row { display: flex; align-items: center; gap: 8px; padding: 7px 0; border-bottom: 1px solid #1e1e1e; font-size: 13px; }
.comp-row:last-child { border-bottom: none; }
.comp-cat { color: var(--text-sub); flex: 1; }
.comp-val1 { color: var(--income); font-weight: 600; width: 70px; text-align: right; }
.comp-val2 { color: #d47fc0; font-weight: 600; width: 70px; text-align: right; }
.comp-delta { font-size: 11px; width: 50px; text-align: right; }
.comp-delta.up { color: var(--expense); }
.comp-delta.down { color: var(--accent); }
.comp-delta.flat { color: var(--muted); }
.comp-totals { display: flex; justify-content: space-between; background: var(--input-bg); border-radius: 10px; padding: 12px; margin-top: 10px; }
.comp-total-item { text-align: center; }
.comp-total-label { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
.comp-total-val { font-size: 16px; font-weight: 700; }

/* ── PROYECCIÓN ── */
.proy-card { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 16px; margin-bottom: 12px; }
.proy-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
.proy-valor { font-size: 26px; font-weight: 700; color: var(--text); }
.proy-valor.ok { color: var(--accent); }
.proy-valor.warn { color: #e8a838; }
.proy-valor.danger { color: #e05252; }
.proy-sub { color: var(--muted); font-size: 12px; margin-top: 4px; }
.proy-cat-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid #222; font-size: 13px; }
.proy-cat-row:last-child { border-bottom: none; }
.proy-cat-nombre { color: var(--text-sub); }
.proy-cat-nums { text-align: right; }
.proy-cat-actual { color: var(--text); font-weight: 600; }
.proy-cat-proyectado { color: var(--muted); font-size: 11px; }

/* ══ PRO: PRESUPUESTOS ══ */
.pres-cat-bar { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 14px; margin-bottom: 10px; }
.pres-cat-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.pres-cat-name { font-size: 13px; font-weight: 600; color: var(--text); }
.pres-cat-nums { font-size: 12px; color: var(--text-sub); }
.pres-cat-nums strong { color: var(--text); }
.pres-cat-track { background: var(--input-bg); border-radius: 20px; height: 10px; overflow: hidden; margin-bottom: 6px; }
.pres-cat-fill { height: 100%; border-radius: 20px; transition: width 0.5s ease; }
.pres-cat-sub { display: flex; justify-content: space-between; font-size: 11px; }
.pres-cat-gastado { color: var(--expense); }
.pres-cat-resta { }
.pres-add-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 10px; color: var(--accent); font-size: 13px; font-weight: 600; padding: 12px; width: 100%; cursor: pointer; margin-top: 8px; }

/* ══ PRO: SUSCRIPCIONES ══ */
.sub-item { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 12px 14px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; gap: 10px; }
.sub-item.alerta { border-color: var(--warn); }
.sub-info { flex: 1; }
.sub-nombre { font-size: 14px; font-weight: 600; color: var(--text); }
.sub-meta { font-size: 11px; color: var(--muted); margin-top: 2px; }
.sub-derecha { text-align: right; }
.sub-monto { font-size: 15px; font-weight: 700; color: var(--expense); }
.sub-dia { font-size: 11px; color: var(--muted); margin-top: 2px; }
.sub-alerta-badge { background: rgba(232,168,56,0.15); border: 1px solid #e8a838; color: #e8a838; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; }
.sub-add-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 10px; color: var(--accent); font-size: 13px; font-weight: 600; padding: 12px; width: 100%; cursor: pointer; margin-top: 8px; }
.sub-del-btn { background: #2a1a1a; border: 1px solid #5a2a2a; border-radius: 8px; color: #e24b4a; font-size: 12px; padding: 6px 10px; cursor: pointer; }

/* ══ PRO: DIFERIDOS ══ */
.dif-item { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 12px 14px; margin-bottom: 10px; }
.dif-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
.dif-nombre { font-size: 14px; font-weight: 600; color: var(--text); }
.dif-meta { font-size: 11px; color: var(--muted); margin-top: 2px; }
.dif-derecha { text-align: right; }
.dif-cuotas { font-size: 13px; font-weight: 700; color: var(--accent); }
.dif-restante { font-size: 11px; color: var(--muted); margin-top: 2px; }
.dif-barra-track { background: var(--input-bg); border-radius: 20px; height: 6px; overflow: hidden; margin-bottom: 8px; }
.dif-barra-fill { height: 100%; border-radius: 20px; background: var(--accent); transition: width 0.5s; }
.dif-acciones { display: flex; gap: 6px; }
.dif-saldar-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 8px; color: var(--accent); font-size: 12px; padding: 7px 12px; cursor: pointer; flex: 1; font-weight: 600; }
.dif-undo-btn { background: #1a1a2a; border: 1px solid #3a3a5a; border-radius: 8px; color: #9b9bd4; font-size: 12px; padding: 7px 10px; cursor: pointer; }
.dif-del-btn { background: #2a1a1a; border: 1px solid #5a2a2a; border-radius: 8px; color: #e24b4a; font-size: 12px; padding: 7px 10px; cursor: pointer; }
.dif-add-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 10px; color: var(--accent); font-size: 13px; font-weight: 600; padding: 12px; width: 100%; cursor: pointer; margin-top: 8px; }
.dif-completado { opacity: 0.5; }
.dif-completado .dif-barra-fill { background: var(--muted); }

/* ══ PRO: CUENTAS POR COBRAR ══ */
.cobrar-item { background: var(--card); border: 1px solid var(--card-brd); border-radius: 12px; padding: 12px 14px; margin-bottom: 8px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 8px; }
.cobrar-deudor { font-size: 14px; font-weight: 600; color: var(--text); }
.cobrar-saldo-cero { color: var(--muted); }
.cobrar-saldo-pos { color: var(--income); font-size: 15px; font-weight: 700; }
.cobrar-saldo-neg { color: var(--expense); font-size: 15px; font-weight: 700; }
.cobrar-add-btn { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 10px; color: var(--accent); font-size: 13px; font-weight: 600; padding: 12px; width: 100%; cursor: pointer; margin-top: 8px; }

/* ── MODAL ── */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 80; display: none; align-items: flex-end; }
.modal-overlay.visible { display: flex; }
.modal-panel { background: var(--sheet-bg); border-radius: 20px 20px 0 0; border-top: 1px solid var(--card-brd); width: 100%; padding: 16px 16px 32px; max-height: 85vh; overflow-y: auto; }
.modal-title { font-size: 15px; font-weight: 600; margin-bottom: 16px; color: var(--text); }
.modal-field { margin-bottom: 12px; }
.modal-field label { color: var(--text-sub); font-size: 11px; display: block; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; }
.modal-field input, .modal-field select { background: var(--input-bg); border: 1px solid var(--card-brd); border-radius: 8px; color: #fff; font-size: 14px; padding: 10px; width: 100%; outline: none; }
.modal-btns { display: flex; gap: 8px; margin-top: 14px; }
.modal-ok { background: var(--accent-dim); border: 1px solid var(--accent-brd); border-radius: 10px; color: var(--accent); font-size: 14px; font-weight: 600; padding: 12px; flex: 1; cursor: pointer; }
.modal-cancel { background: var(--card); border: 1px solid var(--card-brd); border-radius: 10px; color: var(--text-sub); font-size: 14px; padding: 12px; flex: 1; cursor: pointer; }
.modal-danger { background: #2a1a1a; border: 1px solid #5a2a2a; border-radius: 10px; color: #e24b4a; font-size: 14px; padding: 12px; flex: 1; cursor: pointer; }

/* ── MISC ── */
.cache-badge { display: inline-block; background: #2a2000; border: 1px solid #4a3800; color: #a08030; font-size: 10px; padding: 2px 8px; border-radius: 10px; margin-bottom: 8px; }
.offline-banner { background: #1a1000; border: 1px solid #3a2800; border-radius: 10px; color: #a08030; font-size: 12px; padding: 8px 12px; margin-bottom: 12px; display: none; text-align: center; }
.offline-banner.visible { display: block; }
.toast { position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%); background: var(--accent-dim); border: 1px solid var(--accent-brd); color: var(--accent); padding: 12px 24px; border-radius: 20px; font-size: 14px; display: none; z-index: 200; white-space: nowrap; max-width: 90vw; text-align: center; }
.toast.visible { display: block; }
.cola-badge { position: fixed; bottom: 72px; right: 16px; background: #2a1800; border: 1px solid #5a3000; color: #e8a838; font-size: 12px; font-weight: 600; padding: 6px 12px; border-radius: 20px; cursor: pointer; z-index: 150; display: none; -webkit-tap-highlight-color: transparent; }
.cola-badge.visible { display: block; }
.metodo-ciclo-info { background: var(--accent-deep); border: 1px solid var(--accent-brd); border-radius: 8px; color: var(--text-sub); font-size: 11px; padding: 8px 10px; margin-top: 4px; }
.empty-state { color: var(--muted); font-size: 13px; font-style: italic; text-align: center; padding: 24px 0; }
</style>
</head>
<body>

<!-- ══ CONFIG SCREEN ══ -->
<div id="config-screen">
  <div class="header"><h1>🪙 Otto y 10 lucas<span class="pro-badge">PRO</span></h1><p>Pega la URL de tu Google Apps Script para empezar</p></div>
  <div class="config">
    <label>URL de tu Google Apps Script</label>
    <input type="url" id="url-input" placeholder="https://script.google.com/macros/s/..." />
    <button class="save-btn" onclick="guardar()">Conectar</button>
    <div style="margin-top:24px;border-top:1px solid var(--card-brd);padding-top:20px;">
      <div style="color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:0.5px;text-align:center;margin-bottom:10px;">Tema</div>
      <div class="theme-picker">
        <div style="text-align:center;"><div class="theme-dot theme-dot-obsidian active" id="dot-obsidian" onclick="setTema('obsidian')"></div><div style="color:var(--muted);font-size:9px;margin-top:4px;">Gold</div></div>
        <div style="text-align:center;"><div class="theme-dot theme-dot-forest" id="dot-forest" onclick="setTema('forest')"></div><div style="color:var(--muted);font-size:9px;margin-top:4px;">Forest</div></div>
        <div style="text-align:center;"><div class="theme-dot theme-dot-arctic" id="dot-arctic" onclick="setTema('arctic')"></div><div style="color:var(--muted);font-size:9px;margin-top:4px;">Arctic</div></div>
        <div style="text-align:center;position:relative;"><div class="theme-dot theme-dot-sakura" id="dot-sakura" onclick="setTema('sakura')"></div><div style="color:var(--muted);font-size:9px;margin-top:4px;">Sakura ✦</div></div>
      </div>
    </div>
  </div>
</div>

<!-- ══ APP ══ -->
<div id="app" style="display:none">

  <div class="header">
    <h1 onclick="irAlSheets()">🪙 Otto y 10 lucas<span class="pro-badge">PRO</span></h1>
    <p id="status"><span class="connected">Conectado</span></p>
  </div>

  <div class="offline-banner" id="offline-banner">⚠️ Sin conexión — mostrando último dato guardado</div>

  <div class="month-bar">
    <label>Mes</label>
    <select class="month-select" id="month-select" onchange="onMesChange()">
      <option value="1">Enero</option><option value="2">Febrero</option>
      <option value="3">Marzo</option><option value="4">Abril</option>
      <option value="5">Mayo</option><option value="6">Junio</option>
      <option value="7">Julio</option><option value="8">Agosto</option>
      <option value="9">Septiembre</option><option value="10">Octubre</option>
      <option value="11">Noviembre</option><option value="12">Diciembre</option>
    </select>
    <select class="month-select" id="year-select" onchange="onMesChange()" style="flex:0;min-width:64px;text-align:right;"></select>
    <span class="month-arrow">▾</span>
  </div>

  <!-- ── HOME ── -->
  <div class="page active" id="page-home">
    <div class="home-balance">
      <div class="home-balance-label">Balance neto</div>
      <div class="home-balance-val" id="home-balance-val">—</div>
      <div class="home-balance-sub">
        <span class="inc" id="home-ingresos">↑ —</span>
        <span class="exp" id="home-egresos">↓ —</span>
      </div>
    </div>

    <div class="home-hoy">
      <div class="home-hoy-header">
        <span class="home-hoy-label">📅 Hoy</span>
        <span class="home-hoy-total" id="home-hoy-total"></span>
      </div>
      <div id="home-hoy-lista"><span class="home-hoy-empty">Cargando...</span></div>
    </div>

    <!-- PRO: Impacto mes siguiente -->
    <div class="impacto-card" id="impacto-card" onclick="toggleImpacto()" style="display:none">
      <div class="impacto-header">
        <span class="impacto-label">📅 Impacto mes siguiente</span>
        <span class="impacto-total" id="impacto-total">—</span>
        <span class="impacto-arrow" id="impacto-arrow">›</span>
      </div>
      <div class="impacto-desglose" id="impacto-desglose"></div>
    </div>

    <div class="section">
      <div class="section-title">Consultas rápidas</div>
      <div class="btn-grid">
        <button class="btn green" onclick="abrirSheet('resumen','Resumen')"><span class="icon">📊</span>Resumen</button>
        <button class="btn green" onclick="abrirSheet('balance','Balance')"><span class="icon">💰</span>Balance</button>
        <button class="btn" onclick="abrirSheetFn(detalleIngresos)"><span class="icon">📈</span>Ingresos</button>
        <button class="btn" onclick="abrirSheet('egresos','Egresos')"><span class="icon">📉</span>Egresos</button>
        <button class="btn pro" onclick="switchTab('pro')"><span class="icon">💳</span><span class="label">Suscripciones</span></button>
        <button class="btn pro" onclick="switchTab('pro');setTimeout(()=>mostrarProPanel('diferidos'),100)"><span class="icon">🔄</span><span class="label">Diferidos</span></button>
      </div>
    </div>

    <div class="section">
      <div class="section-title">Por categoría</div>
      <div class="btn-grid three" id="home-cats-grid"></div>
    </div>

    <div class="section">
      <div class="section-title">Por método de pago</div>
      <div class="btn-grid" id="home-mets-grid"></div>
    </div>
  </div>

  <!-- ── REGISTRAR ── -->
  <div class="page" id="page-registrar">
    <div class="reg-toggle">
      <div class="reg-toggle-btn active-expense" id="toggle-gasto" onclick="setTipoReg('gasto')">📉 Gasto</div>
      <div class="reg-toggle-btn" id="toggle-ingreso" onclick="setTipoReg('ingreso')">📈 Ingreso</div>
    </div>

    <div class="favs-section" id="favs-section">
      <div class="favs-label">⚡ Rápido</div>
      <div class="favs-wrap" id="favs-wrap">
        <button class="fav-add-btn" onclick="abrirModalFav()">+ Nuevo favorito</button>
      </div>
    </div>

    <div class="form-field">
      <label>Fecha</label>
      <div class="fecha-rapida">
        <button class="fecha-btn active" id="fbtn-hoy" onclick="setFechaRapida(0)">Hoy</button>
        <button class="fecha-btn" id="fbtn-ayer" onclick="setFechaRapida(1)">Ayer</button>
        <button class="fecha-btn" id="fbtn-antier" onclick="setFechaRapida(2)">Antier</button>
      </div>
      <input type="date" id="reg-fecha" onchange="limpiarFechaRapida()" />
    </div>

    <div class="form-field">
      <label>Monto ($)</label>
      <input type="text" id="reg-monto" placeholder="0.00" inputmode="decimal" pattern="[0-9]*[.,]?[0-9]*" />
    </div>

    <div id="campos-gasto">
      <div class="form-field">
        <label>Categoría</label>
        <div class="pill-group" id="cat-pills"></div>
      </div>
      <div class="form-field">
        <label>Método de pago</label>
        <div class="pill-group" id="met-pills"></div>
        <!-- PRO: info de ciclo -->
        <div class="metodo-ciclo-info" id="ciclo-info" style="display:none"></div>
      </div>
    </div>

    <div id="campos-ingreso" style="display:none">
      <div class="form-field">
        <label>Fuente</label>
        <select id="reg-fuente">
          <option value="">Selecciona fuente...</option>
          <option value="Sueldo">💼 Sueldo</option>
          <option value="Freelance">💻 Freelance</option>
          <option value="Bono">🎁 Bono</option>
          <option value="Reembolso">↩️ Reembolso</option>
          <option value="Otro ingreso">📥 Otro ingreso</option>
        </select>
      </div>
    </div>

    <div class="form-field">
      <label>Descripción</label>
      <input type="text" id="reg-desc" placeholder="ej: taxi, almuerzo, sueldo..." />
    </div>

    <button class="submit-btn" id="submit-btn" onclick="registrar()">Registrar gasto</button>
  </div>

  <!-- ── HISTORIAL ── -->
  <div class="page" id="page-historial">
    <div class="hist-filter-wrap" id="hist-filter-wrap"></div>
    <div class="hist-filter-total" id="hist-filter-total">
      <span id="hist-filter-label" style="color:var(--text-sub);font-size:12px;"></span>
      <span id="hist-filter-sum" style="color:var(--expense);font-weight:700;"></span>
    </div>
    <button class="refresh-btn" onclick="cargarHistorial()">↻ Actualizar</button>
    <div id="historial-lista"><p style="color:var(--muted);font-size:13px;">Cargando...</p></div>
  </div>

  <!-- ── ANÁLISIS ── -->
  <div class="page" id="page-analisis">
    <div id="analisis-menu-panel">
      <div class="analisis-menu">
        <div class="analisis-item" onclick="mostrarSubPage('graficos')">
          <span class="analisis-icon">🍩</span>
          <div class="analisis-text"><strong>Gráficos</strong><span>Distribución por categoría</span></div>
          <span class="analisis-arrow">›</span>
        </div>
        <div class="analisis-item" onclick="mostrarSubPage('historico')">
          <span class="analisis-icon">📈</span>
          <div class="analisis-text"><strong>Balance histórico</strong><span>Últimos 6 meses</span></div>
          <span class="analisis-arrow">›</span>
        </div>
        <div class="analisis-item" onclick="mostrarSubPage('comparar')">
          <span class="analisis-icon">🔀</span>
          <div class="analisis-text"><strong>Comparar meses</strong><span>Diferencias por categoría</span></div>
          <span class="analisis-arrow">›</span>
        </div>
        <div class="analisis-item" onclick="mostrarSubPage('proyeccion')">
          <span class="analisis-icon">🔮</span>
          <div class="analisis-text"><strong>Proyección</strong><span>Estimación a fin de mes</span></div>
          <span class="analisis-arrow">›</span>
        </div>
        <div class="analisis-item" onclick="mostrarSubPage('presupuestos')" style="border-color:var(--accent-brd)">
          <span class="analisis-icon">🎯</span>
          <div class="analisis-text"><strong>Presupuestos</strong><span>Control por categoría con semáforo</span></div>
          <span class="analisis-arrow">›</span>
        </div>
      </div>
    </div>

    <!-- Gráficos -->
    <div class="sub-page" id="sub-graficos">
      <button class="back-btn" onclick="volverAnalisis()">← Análisis</button>
      <div class="budget-bar-wrap">
        <div class="budget-bar-header"><span class="budget-bar-label">Sueldo vs Gastos</span><span class="budget-bar-nums" id="budget-nums">—</span></div>
        <div class="budget-bar-track"><div class="budget-bar-fill" id="budget-fill" style="width:0%"></div></div>
        <div class="budget-bar-sub"><span class="budget-bar-spent" id="budget-spent">Gastado: —</span><span class="budget-bar-left" id="budget-left">Disponible: —</span></div>
      </div>
      <div class="chart-container">
        <div class="chart-title">Gastos por categoría</div>
        <canvas id="donaChart" height="260"></canvas>
      </div>
      <div style="background:var(--card);border:1px solid var(--card-brd);border-radius:12px;padding:16px;">
        <div id="legend-body" style="color:var(--muted);font-size:13px;">Cargando...</div>
      </div>
    </div>

    <!-- Histórico -->
    <div class="sub-page" id="sub-historico">
      <button class="back-btn" onclick="volverAnalisis()">← Análisis</button>
      <div class="chart-container"><div class="chart-title">Balance neto mensual</div><canvas id="historicoChart" height="220"></canvas></div>
      <div class="chart-container"><div class="chart-title">Ingresos vs Egresos</div><canvas id="historicoBarChart" height="220"></canvas></div>
      <div id="hist-resumen-lista"></div>
    </div>

