// ── Proyección ────────────────────────────────────────────
async function cargarProyeccion() {
  document.getElementById('proy-loading').style.display = 'block';
  document.getElementById('proy-contenido').style.display = 'none';
  let sueldo = 0, gastoActual = 0, cats = [];
  const c = leerCache('chart');
  if (c?.data?.gastos) { sueldo = c.data.sueldo||0; cats = c.data.gastos; gastoActual = c.data.egresosTotal != null ? c.data.egresosTotal : cats.reduce((a,b)=>a+b.valor,0); }
  try {
    const res  = await fetch(urlConMes('chart'), { redirect: 'follow' });
    const data = await res.json();
    guardarCache('chart', data);
    if (data.gastos) { sueldo = data.sueldo||0; cats = data.gastos; gastoActual = data.egresosTotal != null ? data.egresosTotal : cats.reduce((a,b)=>a+b.valor,0); }
  } catch {}
  if (!sueldo && !gastoActual) { document.getElementById('proy-loading').innerHTML = '<p style="color:var(--muted);font-size:13px;">Sin datos.</p>'; return; }
  const hoy = new Date();
  const esMesActual = (mesSeleccionado-1) === hoy.getMonth() && anioSeleccionado === hoy.getFullYear();
  const diasEnMes   = new Date(anioSeleccionado, mesSeleccionado, 0).getDate();
  const diaActual   = esMesActual ? hoy.getDate() : diasEnMes;
  const gastoDiario = diaActual > 0 ? gastoActual/diaActual : 0;
  const proyeccionFin = gastoDiario * diasEnMes;
  const disponible    = sueldo - proyeccionFin;
  const pctMes = Math.round((diaActual/diasEnMes)*100);
  document.getElementById('proy-loading').style.display   = 'none';
  document.getElementById('proy-contenido').style.display = 'block';
  document.getElementById('proy-diario').textContent     = '$' + gastoDiario.toFixed(2) + '/día';
  document.getElementById('proy-dias-trans').textContent  = 'Basado en ' + diaActual + ' días';
  const pEl = document.getElementById('proy-total-mes');
  pEl.textContent = '$' + proyeccionFin.toFixed(2);
  pEl.className   = 'proy-valor' + (proyeccionFin > sueldo ? ' danger' : proyeccionFin > sueldo*0.85 ? ' warn' : ' ok');
  document.getElementById('proy-total-sub').textContent   = 'Gastado: $' + gastoActual.toFixed(2);
  const dEl = document.getElementById('proy-disponible');
  dEl.textContent = '$' + Math.abs(disponible).toFixed(2) + (disponible < 0 ? ' en rojo' : ' sobrante');
  dEl.className   = 'proy-valor' + (disponible < 0 ? ' danger' : disponible < sueldo*0.1 ? ' warn' : ' ok');
  document.getElementById('proy-disponible-sub').textContent = sueldo > 0 ? 'Ingresos $' + sueldo.toFixed(2) + ' − proyección $' + proyeccionFin.toFixed(2) : '';
  const fill = document.getElementById('proy-mes-fill');
  fill.style.width = pctMes + '%';
  fill.className   = 'budget-bar-fill' + (pctMes >= 90 ? ' danger' : pctMes >= 70 ? ' warn' : '');
  document.getElementById('proy-dia-actual').textContent = 'Día ' + diaActual + ' de ' + diasEnMes;
  document.getElementById('proy-dias-rest').textContent  = (diasEnMes-diaActual) + ' días restantes';
  document.getElementById('proy-cats').innerHTML = cats.map(c => {
    const proy = diaActual > 0 ? (c.valor/diaActual)*diasEnMes : 0;
    return `<div class="proy-cat-row"><span class="proy-cat-nombre">${c.nombre}</span><span class="proy-cat-nums"><span class="proy-cat-actual">$${c.valor.toFixed(2)}</span><span class="proy-cat-proyectado"> → $${proy.toFixed(2)}</span></span></div>`;
  }).join('');
}

// ── Comparar ──────────────────────────────────────────────
async function ejecutarComparar() {
  const mes1  = document.getElementById('comp-mes1').value;
  const anio1 = document.getElementById('comp-anio1').value;
  const mes2  = document.getElementById('comp-mes2').value;
  const anio2 = document.getElementById('comp-anio2').value;
  const res = document.getElementById('comp-resultado');
  res.innerHTML = '<p style="color:var(--muted);font-size:13px;">Cargando...</p>';
  try {
    const [r1, r2] = await Promise.all([
      fetch(scriptUrl + '?cmd=chart&mes=' + mes1 + '&anio=' + anio1, { redirect: 'follow' }).then(r => r.json()),
      fetch(scriptUrl + '?cmd=chart&mes=' + mes2 + '&anio=' + anio2, { redirect: 'follow' }).then(r => r.json())
    ]);
    const map1 = {}, map2 = {};
    (r1.gastos||[]).forEach(g => map1[g.nombre] = g.valor);
    (r2.gastos||[]).forEach(g => map2[g.nombre] = g.valor);
    const allCats = [...new Set([...Object.keys(map1), ...Object.keys(map2)])];
    const rows = allCats.map(cat => {
      const v1 = map1[cat] || 0, v2 = map2[cat] || 0;
      const delta = v1 - v2;
      const cls = delta > 0 ? 'up' : delta < 0 ? 'down' : 'flat';
      const sign = delta > 0 ? '+' : '';
      return `<div class="comp-row">
        <span class="comp-cat">${cat}</span>
        <span class="comp-val1">$${v1.toFixed(2)}</span>
        <span class="comp-val2">$${v2.toFixed(2)}</span>
        <span class="comp-delta ${cls}">${sign}$${Math.abs(delta).toFixed(0)}</span>
      </div>`;
    }).join('');
    const t1 = Object.values(map1).reduce((a,b)=>a+b,0);
    const t2 = Object.values(map2).reduce((a,b)=>a+b,0);
    res.innerHTML = `
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-bottom:8px;font-size:11px;color:var(--muted);">
        <span style="color:var(--income);width:70px;text-align:right;">${MESES_LABEL[mes1-1]}</span>
        <span style="color:#d47fc0;width:70px;text-align:right;">${MESES_LABEL[mes2-1]}</span>
        <span style="width:50px;"></span>
      </div>
      ${rows}
      <div class="comp-totals">
        <div class="comp-total-item"><div class="comp-total-label">${MESES_LABEL[mes1-1]}</div><div class="comp-total-val" style="color:var(--income);">$${t1.toFixed(2)}</div></div>
        <div class="comp-total-item"><div class="comp-total-label">Diferencia</div><div class="comp-total-val" style="color:${t1>t2?'#e07070':'#7fd4a0'};">${t1>t2?'+':''}$${(t1-t2).toFixed(2)}</div></div>
        <div class="comp-total-item"><div class="comp-total-label">${MESES_LABEL[mes2-1]}</div><div class="comp-total-val" style="color:#d47fc0;">$${t2.toFixed(2)}</div></div>
      </div>`;
  } catch { res.innerHTML = '<p class="error">Error al comparar.</p>'; }
}

// ══ PRO: PRESUPUESTOS ══════════════════════════════════════
async function cargarPresupuestos() {
  const lista = document.getElementById('presupuestos-lista');
  lista.innerHTML = '<p style="color:var(--muted);font-size:13px;">Cargando...</p>';
  try {
    const [presData, chartData] = await Promise.all([
      fetch(urlConMes('presupuestos'), { redirect: 'follow' }).then(r => r.json()),
      fetch(urlConMes('chart'), { redirect: 'follow' }).then(r => r.json()).catch(() => ({ gastos: [] }))
    ]);
    if (!presData.length) {
      lista.innerHTML = '<p class="empty-state">Sin presupuestos configurados.<br>Toca "Agregar presupuesto" para comenzar.</p>';
      return;
    }
    // Merge con gastos reales del mes si el script los devuelve
    const gastosMap = {};
    (chartData.gastos || []).forEach(g => gastosMap[g.nombre] = g.valor);

    lista.innerHTML = presData.map(p => {
      const gastado = p.gastado || gastosMap[p.categoria] || 0;
      const limite  = p.limite || 0;
      const pct     = limite > 0 ? Math.min((gastado / limite) * 100, 100) : 0;
      const resta   = limite - gastado;
      const colorClass = pct >= 90 ? 'danger' : pct >= 70 ? 'warn' : 'ok';
      const fillBg = pct >= 90 ? 'linear-gradient(90deg,#e05252,#f08080)' : pct >= 70 ? 'linear-gradient(90deg,#e8a838,#f5c870)' : 'linear-gradient(90deg,var(--accent-dim),var(--accent))';
      return `<div class="pres-cat-bar" id="pres-${p.categoria.replace(/\s/g,'-')}">
        <div class="pres-cat-header">
          <span class="pres-cat-name">${p.icono || ''} ${p.categoria}</span>
          <span class="pres-cat-nums"><strong>$${gastado.toFixed(2)}</strong> / $${limite.toFixed(2)}</span>
        </div>
        <div class="pres-cat-track"><div class="pres-cat-fill" style="width:${pct}%;background:${fillBg}"></div></div>
