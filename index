// ── Home ──────────────────────────────────────────────────
async function cargarHome() {
  const cachedBal = leerCache('balance_json');
  if (cachedBal?.data) renderHomeBalance(cachedBal.data);
  const cachedHoy = leerCache('hoy_raw');
  if (cachedHoy?.data) renderHomeHoy(cachedHoy.data);

  try {
    const [balR, hoyR] = await Promise.allSettled([
      fetch(urlConMes('balance_json'), { redirect: 'follow' }),
      fetch(urlConMes('hoy'),          { redirect: 'follow' })
    ]);
    let huboError = false;
    if (balR.status === 'fulfilled') {
      try { const d = await balR.value.json(); guardarCache('balance_json', d); renderHomeBalance(d); }
      catch { huboError = true; }
    } else { huboError = true; }
    if (hoyR.status === 'fulfilled') {
      try { const t = await hoyR.value.text(); guardarCache('hoy_raw', t); renderHomeHoy(t); }
      catch { huboError = true; }
    } else { huboError = true; }
    mostrarOfflineBanner(huboError);
    verificarSinClasificar();
  } catch { mostrarOfflineBanner(true); }
}

function renderHomeBalance(data) {
  const ingresos = parseFloat(data.ingresos) || 0;
  const egresos  = parseFloat(data.egresos)  || 0;
  const balance  = parseFloat(data.balance)  || 0;
  const el = document.getElementById('home-balance-val');
  el.textContent = (balance >= 0 ? '' : '-') + '$' + Math.abs(balance).toFixed(2);
  el.className = 'home-balance-val' + (balance < 0 ? ' danger' : balance < ingresos * 0.1 ? ' warn' : '');
  document.getElementById('home-ingresos').textContent = '↑ $' + ingresos.toFixed(2);
  document.getElementById('home-egresos').textContent  = '↓ $' + egresos.toFixed(2);
}

function renderHomeHoy(txt) {
  const lista   = document.getElementById('home-hoy-lista');
  const totalEl = document.getElementById('home-hoy-total');
  if (!txt || txt.includes('No hay gastos')) {
    lista.innerHTML = '<span class="home-hoy-empty">Sin gastos hoy 🎉</span>';
    totalEl.textContent = '';
    return;
  }
  const lineas = txt.replace('📅 Gastos de hoy\n\n','').split('\n').filter(l => l.startsWith('• '));
  const totalMatch = txt.match(/Total: \$(.+)/);
  if (totalMatch) totalEl.textContent = '$' + totalMatch[1];
  lista.innerHTML = lineas.slice(0, 5).map(l => {
    const m = l.match(/• (.+?) — (.+?) \((.+?)\): \$(.+)/);
    if (!m) return `<div class="home-hoy-item"><span class="home-hoy-desc">${l.replace('• ','')}</span></div>`;
    return `<div class="home-hoy-item">
      <span class="home-hoy-desc">${m[2]}</span>
      <span class="home-hoy-meta">${m[1]} · ${m[3]}</span>
      <span class="home-hoy-monto">$${m[4]}</span>
    </div>`;
  }).join('') + (lineas.length > 5 ? `<div style="color:var(--muted);font-size:11px;padding-top:6px;">+${lineas.length-5} más</div>` : '');
}

