(function() {
  const t = localStorage.getItem('otto_tema') || 'obsidian';
  if (t !== 'obsidian') document.documentElement.setAttribute('data-theme', t);
  setTimeout(() => {
    TEMAS_VALIDOS.forEach(n => {
      ['dot-'+n,'dot-'+n+'-cfg'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.toggle('active', n === t);
      });
    });
  }, 0);
})();
